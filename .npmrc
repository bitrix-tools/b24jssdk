# Hoist runtime deps (vite, esbuild, sharp, etc.) to root node_modules so IDEs
# and ad-hoc scripts that don't go through pnpm's bin resolution can find them.
# This does NOT reliably hoist workspace-member binaries (nuxt, eslint) to the
# root on Windows / strict-store layouts — root scripts therefore delegate via
# `pnpm --filter ./docs run <cmd>` instead of relying on hoisting (see PR #8).
shamefully-hoist=true
auto-install-peers=true
ignore-workspace-root-check=true
node-options=--max-old-space-size=8192

{
  "name": "@bitrix24/b24jssdk-docs-ru",
  "description": "Russian documentation for @bitrix24/b24jssdk",
  "version": "1.1.2",
  "author": "Bitrix",
  "packageManager": "pnpm@11.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitrix-tools/b24jssdk.git"
  },
  "homepage": "https://bitrix-tools.github.io/b24jssdk/",
  "type": "module",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bitrix24/b24jssdk/issues"
  },
  "private": true,
  "sideEffects": false,
  "scripts": {
    "docs:dev": "pnpm --filter ./docs run dev",
    "docs:prepare": "pnpm --filter ./docs run prepare",
    "docs:build": "pnpm --filter ./docs run build",
    "docs:generate": "pnpm --filter ./docs run generate",
    "docs:preview": "pnpm --filter ./docs run preview",
    "docs:lint": "pnpm --filter ./docs run lint",
    "docs:typecheck": "pnpm --filter ./docs run typecheck",
    "dev": "pnpm run docs:dev",
    "build": "pnpm run docs:build",
    "generate": "pnpm run docs:generate",
    "preview": "pnpm run docs:preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm run docs:typecheck",
    "i18n:add-anchors": "node scripts/add-anchors.mjs",
    "i18n:add-anchors:dry": "node scripts/add-anchors.mjs --dry-run",
    "i18n:swap-apidocs": "node scripts/swap-apidocs.mjs",
    "i18n:swap-apidocs:dry": "node scripts/swap-apidocs.mjs --dry-run",
    "i18n:prep": "pnpm run i18n:add-anchors && pnpm run i18n:swap-apidocs"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@types/node": "^25.3.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "typescript": "^5.6.3 || ^6.0.0"
  },
  "keywords": [
    "bitrix24",
    "docs",
    "russian",
    "jssdk"
  ],
  "dependencies": {
    "remark-custom-heading-id": "^2.0.0"
  }
}
